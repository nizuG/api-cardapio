generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  senha    String
  tipo     String   @default("CLIENTE")
  criadoEm DateTime @default(now())

  pedidos Pedido[]
}

model Pedido {
  id             Int          @id @default(autoincrement())
  usuarioId      Int
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  tipo           String
  formaPagamento String
  trocoPara      Float?
  status         String       @default("PENDENTE")
  total          Float
  criadoEm       DateTime     @default(now())
  itens          ItemPedido[]
  endereco Endereco?
}

model ItemPedido {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  pedido        Pedido  @relation(fields: [pedidoId], references: [id])
  produtoId     Int
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Float
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  itens ItemPedido[]
}

model Endereco {
  id          Int     @id @default(autoincrement())
  pedidoId    Int     @unique
  pedido      Pedido  @relation(fields: [pedidoId], references: [id])

  rua         String
  numero      String
  bairro      String
  cidade      String
  complemento String?
  referencia  String?
}